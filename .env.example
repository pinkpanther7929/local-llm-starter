# Copy to .env and adjust for your machine.

# Compose profile:
# - vllm: docker compose --profile vllm up -d --build
# - ollama: docker compose --profile ollama up -d
COMPOSE_PROFILES=vllm

# Common ports.
OPEN_WEBUI_PORT=3000
AGENT_GATEWAY_PORT=8010
SEARXNG_PORT=8081

# Open WebUI talks to the local gateway with this key.
OPENAI_API_KEY=sk-local

# Gateway points at any OpenAI-compatible /v1 backend.
LLM_BASE_URL=http://vllm:8000/v1
SERVED_MODEL_NAME=qwen-14b

# Hugging Face token is required when model access is gated or not cached locally.
HF_TOKEN=

# vLLM profile.
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen3-14B-AWQ
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.85

# Ollama profile. Set LLM_BASE_URL=http://ollama:11434/v1 and SERVED_MODEL_NAME
# to an installed Ollama model, for example llama3.1:8b.
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=24h

# SearXNG serves Open WebUI web search on the internal Docker network.
# Rotate searxng/settings.yml server.secret_key before exposing it beyond localhost.

# Agent gateway tuning.
MAX_TOOL_ROUNDS=4
UPSTREAM_RETRIES=6
UPSTREAM_RETRY_DELAY_SECONDS=2
