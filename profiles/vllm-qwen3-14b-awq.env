# vLLM profile for a single RTX 4090 24GB class machine.
COMPOSE_PROFILES=vllm

UPSTREAM_BASE_URL=http://vllm:8000/v1
SERVED_MODEL_NAME=qwen-14b

MODEL_ID=Qwen/Qwen3-14B-AWQ
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.85

VLLM_PORT=8000
OPEN_WEBUI_PORT=3000
AGENT_GATEWAY_PORT=8010
SEARXNG_PORT=8081
SEARXNG_PUBLIC_URL=http://localhost:8081/

HF_TOKEN=
